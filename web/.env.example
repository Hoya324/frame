# Supabase (Project Settings → API). The publishable/anon key is public by design; RLS protects data.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-PUBLISHABLE-OR-ANON-KEY

# Amplitude Analytics. The browser write key is public by design (it only
# authorizes sending events). Optional — a working default is baked into the
# code, so set this only to point at a different Amplitude project.
NEXT_PUBLIC_AMPLITUDE_API_KEY=163467815a1f0224b652bdb1e67bec8c
